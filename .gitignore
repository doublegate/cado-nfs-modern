# out-of-tree build directories (build/<hostname> from call_cmake.sh; build-gpu
# from the -DENABLE_GPU CUDA build) -- never committed
/build/
/build-gpu/

# Python bytecode caches from the orchestration layer
__pycache__/
*.pyc

# Rust build output
/rust/target/

# Local Claude Code tooling and private per-project notes (never committed)
/.claude/
/CLAUDE.local.md

# Local Python venv for the 3.0.0 orchestrator (created by scripts/setup-venv.sh)
/cado-nfs.venv/

# Standalone validation/bench binaries the docs build straight into the repo
# root (e.g. `nvcc ... -o gpu-prefactor`, `gcc ... -o ifma-modmul`). These are
# disposable artifacts, never committed -- the sources live in bench/.
/gpu-prefactor
/gpu-prefactor-bench
/gpu-spmv-bench
/spmv-sweep
/gpu-vecreduce-bench
/gpu-addmul-bench
/gpu-xdotprod-bench
/ifma-modmul
/vpclmul-test
/bench-*
# v3.2.0 standalone benches
/gpu-ecm-edwards
/gpu-ecm-mp
/gpu-batch-smooth
/gpu-sieve-scatter
/gpu-polyselect-collision
/ifma-gfp
/vpclmul-muln
/vpclmul-mul1n-test
/vpclmul-muln-test
/avx512-modinv
# v3.3.0 standalone benches
/avx2-modinv
/gpu-ropt-stage2
/gpu-lingen-ntt
# v3.4.0 standalone benches
/gpu-prefactor-pm1pp1
/gpu-ropt-threshold
/gpu-lingen-ntt-crt
# compiled outputs of the bench/harness/ header validators (sources kept)
/bench/harness/hdrtest
/bench/harness/hdrtest_pclmul

# Profiling / PGO artifacts (gcc -fprofile-generate/-use, perf, gcov)
*.gcda
*.gcno
*.profraw
*.profdata
perf.data
perf.data.old

# Machine-readable run-status snapshots (cado-nfs.py --json-status FILE)
/status.json

# autotools regeneration leftovers (autoreconf in gf2x/) and editor/OS cruft
autom4te.cache/
*.orig
*~
*.swp
.DS_Store
core
core.*
